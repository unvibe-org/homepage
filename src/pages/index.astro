                style="display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;"
            >
                <a href="https://luma.com/lj9niymo" class="btn-primary"
                    >Register →</a
                >
                <a href="mailto:dominik.grusemann@gmail.com" class="btn-ghost"
                    >Any questions? Write us</a
                >
            </div>
            <p
                style="font-size: 11px; color: var(--text-muted); margin-top: 24px;"
            >
                May 13, 2026 · WERK1 Munich · 1–6 PM
            </p>
        </div>
    </section>
</BaseLayout>

<script is:inline>
    (function () {
        var form = document.getElementById("signup-form");
        var feedback = document.getElementById("signup-feedback");
        if (!form) return;

        form.addEventListener("submit", function (e) {
            e.preventDefault();
            var email = form.querySelector('[name="fields[email]"]');
            if (!email.value || !email.validity.valid) {
                feedback.textContent =
                    "→ please enter a valid email address";
                feedback.className = "signup-feedback error";
                return;
            }

            var btn = form.querySelector(".signup-btn");
            btn.textContent = "sending…";
            btn.disabled = true;

            fetch(
