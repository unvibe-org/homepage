---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getNextEvent, getPastEvents } from "../data/eventHelpers";

const nextEvent = getNextEvent();
const pastEvents = getPastEvents();
const hasUpcoming = nextEvent !== null;
const lastEvent = pastEvents[0] ?? null;

const metaDesc = `Hands-on AI coding workshops for engineering teams. One day, on your codebase, with Claude Code or Codex. On-site or remote.`;
const metaDescShort = `AI coding workshops for engineering teams. On-site or remote.`;

// Corporate booking is the single conversion path while positioning is
// per-workshop (no public per-seat tickets on the page for now).
// TODO (docs/homepage-research-2026-07-09.md §3.1-2): switch to hello@unvibe.org
// + an embedded scheduler once the mailbox / Cal.com account exist.
const bookMailto = `mailto:dominik.grusemann@gmail.com?subject=${encodeURIComponent("Workshop for our team")}&body=${encodeURIComponent("Team size:\nPreferred dates:\nOn-site or remote:\n")}`;
---

<BaseLayout
    title="unvibe — AI Coding Workshops for Engineering Teams · Munich"
    description={metaDesc}
    canonical="https://unvibe.org"
    ogTitle="unvibe — AI Coding Workshops for Engineering Teams"
    ogDescription={metaDesc}
    ogImage="https://unvibe.org/public/og-image.png?v=2"
    twitterTitle="unvibe — AI Coding Workshops for Engineering Teams"
    twitterDescription={metaDescShort}
    twitterImage="https://unvibe.org/public/twitter-card.png?v=2"
    includeManifest={true}
    ctaUrl={bookMailto}
    ctaLabel="Get a quote →"
    footerLine={undefined}
>
    <section id="hero">
        <div class="hero-glow"></div>
        <div class="hero-inner">
            <div class="hero-prompt">
                <span class="path">~/workshop</span>
                <span class="cmd">$ run agentic-engineering --mode workshop</span>
            </div>

            <div class="hero-wordmark">
                unvibe<span class="dot">.</span>
            </div>
            <h1 class="hero-tagline">
                From vibe coding to agentic&nbsp;engineering.
            </h1>

            <p class="hero-desc">
                A one-day, hands-on workshop for up to 20 of your engineers,
                on your own codebase, with Claude Code or Codex. On-site or
                remote. Your team leaves with workflows they use the next
                morning.
            </p>

            <div class="hero-actions">
                <a href={bookMailto} class="btn-primary">Get a quote →</a>
                <a href="/guide/" class="btn-ghost">Get the free guide →</a>
            </div>

            {hasUpcoming && (
                <div class="hero-meta">
                    <div class="hero-meta-item">
                        <div class="label">Date</div>
                        <div class="value">{nextEvent.dateDisplay}</div>
                    </div>
                    <div class="hero-meta-item">
                        <div class="label">Time</div>
                        <div class="value">{nextEvent.time}</div>
                    </div>
                    <div class="hero-meta-item">
                        <div class="label">Location</div>
                        <div class="value">{nextEvent.venue}</div>
                    </div>
                </div>
            )}
        </div>

        {/*
          EARLY SOCIAL PROOF — attendee-company logos, pinned to the bottom of
          the hero. Nominative use: these are past attendees' EMPLOYERS, not
          clients/sponsors — hence "Engineers from", not "Trusted by".
          Companies validated in
          workshops/research/signals/2026-05-13-luma-registrations.md.
        */}
        <div class="hero-logos">
            <p class="logo-strip-label">Engineers from teams at</p>
            <div class="logo-strip-grid">
                <img src="/public/logos/infineon.svg" alt="Infineon" />
                <img src="/public/logos/bsh.svg" alt="BSH Hausgeräte" />
                <img src="/public/logos/cocrafter.png" alt="CoCrafter" />
                <img src="/public/logos/qplix.svg" alt="QPLIX" class="logo-stacked" />
            </div>
        </div>
    </section>

    <section id="courses">
        <div class="max-w">
            <div class="section-label">Workshops</div>
            <h2 class="section-title">The workshops.</h2>

            <div class="course-tabs" role="tablist" aria-label="Courses">
                <button
                    class="course-tab"
                    id="tab-foundations"
                    role="tab"
                    aria-selected="true"
                    aria-controls="panel-foundations"
                >
                    <span class="course-tab-title">AI Coding for Software Engineers</span>
                    {hasUpcoming && (
                        <span class="course-tab-badge live">
                            Next open session: {nextEvent.dateDisplay}
                        </span>
                    )}
                </button>
                <button
                    class="course-tab"
                    id="tab-advanced"
                    role="tab"
                    aria-selected="false"
                    aria-controls="panel-advanced"
                >
                    <span class="course-tab-title">Advanced AI Coding</span>
                </button>
            </div>

            <div
                class="course-panel"
                id="panel-foundations"
                role="tabpanel"
                aria-labelledby="tab-foundations"
            >
                <p class="course-pitch">
                    One hands-on day on your codebase. Your engineers practice
                    directing agents on real work from your backlog, with an
                    instructor alongside. No slideware, no sample project.
                </p>

                <div class="learn-grid">
                    <div class="learn-item">Context engineering: CLAUDE.md files and skills your agents follow</div>
                    <div class="learn-item">Driving agents to consistent, high-quality output</div>
                    <div class="learn-item">Splitting work so the agent never drowns its context</div>
                    <div class="learn-item">Test loops and review workflows that keep up with AI-speed PRs</div>
                    <div class="learn-item">Git branches and worktrees for agent-driven workflows</div>
                    <div class="learn-item">Knowing what to delegate — and when to take the wheel back</div>
                </div>

                <div class="format-strip">
                    <div class="format-step">
                        <span class="what">Foundations, setup on your stack</span>
                    </div>
                    <span class="format-arrow">→</span>
                    <div class="format-step">
                        <span class="what">Hands-on: your codebase, instructors alongside</span>
                    </div>
                    <span class="format-arrow">→</span>
                    <div class="format-step">
                        <span class="what">Wrap-up: what your team adopts on Monday</span>
                    </div>
                </div>
                <p class="agenda-note">
                    The shape of the day. We tailor it to your team.
                </p>

                <div class="course-booking">
                    <div class="course-facts">
                        <div class="fact">
                            <span class="key">Format</span>
                            <span class="val amber">Private workshop for your team</span>
                        </div>
                        <div class="fact">
                            <span class="key">Size</span>
                            <span class="val">Up to 20 engineers</span>
                        </div>
                        <div class="fact">
                            <span class="key">Where</span>
                            <span class="val">On-site or remote</span>
                        </div>
                        <div class="fact">
                            <span class="key">Pricing</span>
                            <span class="val">Per workshop — get a quote</span>
                        </div>
                    </div>
                </div>

                <div class="course-actions">
                    <a href={bookMailto} class="btn-primary">Get a quote →</a>
                    <a href="/guide/" class="btn-ghost">Download the free guide →</a>
                </div>
            </div>

            <div
                class="course-panel"
                id="panel-advanced"
                role="tabpanel"
                aria-labelledby="tab-advanced"
                hidden
            >
                <p class="course-pitch">
                    For engineers who can already direct a single agent well.
                    Now they learn to run several at once, and to spread that
                    discipline across the team.
                </p>

                <div class="learn-grid">
                    <div class="learn-item">Multi-agent orchestration and parallel workflows</div>
                    <div class="learn-item">Custom harnesses, hooks, and automation pipelines</div>
                    <div class="learn-item">Long-running autonomous agents you can leave unattended</div>
                    <div class="learn-item">Rolling agentic engineering out across a team</div>
                </div>

                <div class="format-strip">
                    <div class="format-step">
                        <span class="what">Orchestration foundations</span>
                    </div>
                    <span class="format-arrow">→</span>
                    <div class="format-step">
                        <span class="what">Hands-on: multi-agent workflows on your codebase</span>
                    </div>
                    <span class="format-arrow">→</span>
                    <div class="format-step">
                        <span class="what">Wrap-up: rolling it out across your team</span>
                    </div>
                </div>
                <p class="agenda-note">
                    The shape of the day. We tailor it to your team.
                </p>

                <div class="course-booking">
                    <div class="course-facts">
                        <div class="fact">
                            <span class="key">Format</span>
                            <span class="val amber">Private workshop for your team</span>
                        </div>
                        <div class="fact">
                            <span class="key">Level</span>
                            <span class="val">Comfortable directing one agent</span>
                        </div>
                        <div class="fact">
                            <span class="key">Size</span>
                            <span class="val">Up to 20 engineers</span>
                        </div>
                        <div class="fact">
                            <span class="key">Where</span>
                            <span class="val">On-site or remote</span>
                        </div>
                        <div class="fact">
                            <span class="key">Pricing</span>
                            <span class="val">Per workshop — get a quote</span>
                        </div>
                    </div>
                </div>

                <div class="course-actions">
                    <a href={bookMailto} class="btn-primary">Get a quote →</a>
                    <a href="/guide/" class="btn-ghost">Download the free guide →</a>
                </div>
            </div>
        </div>
    </section>

    <section id="testimonials">
        <div class="max-w">
            <div class="section-label">Testimonial</div>
            <h2 class="section-title">From the first edition.</h2>

            {/*
              Anchor testimonial. Consent received from Alex Kliotzkin (2026-07-01):
              title kept as "Director of Engineering · Infineon" (his call, for
              marketing), figure softened to "hundreds of repos", headshot approved.
              Em dashes removed at his request so it reads like a real quote.
              Quote text is consented verbatim — do not edit.
              Source: workshops/2-marketing/testimonials/tracker.md
            */}
            <div class="quote-card featured">
                <blockquote>
                    "There's so much noise around agentic AI, and a lot of
                    pressure to use it well. The hard part is telling the noise
                    from the actual value. What convinced me was having engineers
                    who've gone deep in the tech and teach tool-agnostic
                    fundamentals you can carry into day-to-day work. My team came
                    back building in an AI-friendly way, and we used it to migrate
                    hundreds of repos at scale."
                </blockquote>
                <div class="quote-attribution">
                    <img
                        src="/public/alex-kliotzkin.jpg"
                        alt="Alex Kliotzkin"
                        class="quote-avatar"
                    />
                    <div>
                        <div class="author">Alex Kliotzkin</div>
                        <div class="role">Director of Engineering · Infineon</div>
                    </div>
                </div>
            </div>

            {lastEvent && (
                <p class="past-line">
                    First edition: {lastEvent.dateDisplay} · {lastEvent.venue}
                    {lastEvent.attendeeCount && ` · ${lastEvent.attendeeCount} engineers`}
                    {lastEvent.recap && (
                        <> · <a href={lastEvent.recap}>See recap →</a></>
                    )}
                </p>
            )}
        </div>
    </section>

    <section id="why">
        <div class="max-w">
            <div class="section-label">Why</div>
            <h2 class="section-title">Vibe coding has a ceiling.</h2>
            <p class="section-desc">
                Prompting your way to a prototype is easy. Production is where
                it breaks down:
            </p>

            <div class="why-grid">
                <div class="why-item">
                    <h3>The review bottleneck</h3>
                    <p>AI writes PRs faster than anyone can review them.</p>
                </div>
                <div class="why-item">
                    <h3>Output you can't control</h3>
                    <p>Same prompt, different architecture, every run.</p>
                </div>
                <div class="why-item">
                    <h3>Context collapse</h3>
                    <p>Long sessions degrade from signal into noise.</p>
                </div>
                <div class="why-item">
                    <h3>The vibe coding hangover</h3>
                    <p>You ship code you don't fully understand — and own it.</p>
                </div>
            </div>

            <p class="why-close">
                Our workshops teach the discipline that fixes this:
                <span class="amber">you set the direction, agents execute, you own the result.</span>
            </p>
        </div>
    </section>

    <section id="audience">
        <div class="max-w">
            <div class="section-label">Who it's for</div>
            <h2 class="section-title">Who to send.</h2>

            <div class="audience-cols">
                <div class="audience-card yes">
                    <h3>✓ Send engineers who</h3>
                    <ul class="audience-list">
                        <li>Write code daily</li>
                        <li>Can read a diff and spot when it's wrong</li>
                        <li>Want techniques to apply the next day</li>
                    </ul>
                    <p class="audience-note">
                        Prior agent experience helps but isn't required. We
                        cover tool fundamentals in the intro.
                    </p>
                </div>
                <div class="audience-card no">
                    <h3>✕ Not a fit</h3>
                    <ul class="audience-list">
                        <li>Non-engineers</li>
                        <li>Teams after a no-code / Lovable-style workflow</li>
                        <li>Anyone wanting theory without hands-on practice</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section id="instructors">
        <div class="max-w">
            <div class="section-label">Instructors</div>
            <h2 class="section-title">The people teaching it ship code for a living.</h2>
            <p class="section-desc">All four use Claude Code and Codex in their own companies, daily.</p>

            <div class="instructor-grid">
                <div class="instructor-card">
                    <img
                        src="/public/traun-leyden.jpg"
                        alt="Traun Leyden"
                        class="instructor-avatar"
                    />
                    <h3>Traun Leyden</h3>
                    <p>
                        Cofounder of <a href="https://fluensy.app/">Fluensy</a>.
                        Ex-Databricks / Couchbase — 20+ years shipping backend
                        systems.
                    </p>
                    <a
                        href="https://www.linkedin.com/in/tleyden/"
                        class="instructor-handle"
                        target="_blank"
                        aria-label="Traun Leyden on LinkedIn"
                        ><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg
                        ></a
                    >
                </div>
                <div class="instructor-card">
                    <img
                        src="/public/adam-charnock.jpg"
                        alt="Adam Charnock"
                        class="instructor-avatar"
                    />
                    <h3>Adam Charnock</h3>
                    <p>
                        Founder of Lithus — bare-metal Kubernetes for SMEs.
                        Previously Twitter and Blocknative. 18 years in
                        production.
                    </p>
                    <a
                        href="https://www.linkedin.com/in/adamcharnock/"
                        class="instructor-handle"
                        target="_blank"
                        aria-label="Adam Charnock on LinkedIn"
                        ><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg
                        ></a
                    >
                </div>
                <div class="instructor-card">
                    <img
                        src="/public/dominik-grusemann.jpg"
                        alt="Dominik Grusemann"
                        class="instructor-avatar"
                    />
                    <h3>Dominik Grusemann</h3>
                    <p>
                        Co-founder of <a href="https://www.usemarbles.com/">Marbles AI</a>.
                        Ex-CTO of Chatchamp (acquired 2023). Ex-BMW autonomous
                        driving.
                    </p>
                    <a
                        href="https://www.linkedin.com/in/dominikgrusemann/"
                        class="instructor-handle"
                        target="_blank"
                        aria-label="Dominik Grusemann on LinkedIn"
                        ><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg
                        ></a
                    >
                </div>
                <div class="instructor-card">
                    <img
                        src="/public/luca-dombetzki.jpg"
                        alt="Luca Dombetzki"
                        class="instructor-avatar"
                    />
                    <h3>Luca Dombetzki</h3>
                    <p>
                        Founder of Get-Ikigai — agentic harnesses for
                        enterprise recruiting. Built TUM.ai, Europe's largest
                        AI student initiative.
                    </p>
                    <a
                        href="https://www.linkedin.com/in/luca-dombetzki"
                        class="instructor-handle"
                        target="_blank"
                        aria-label="Luca Dombetzki on LinkedIn"
                        ><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg
                        ></a
                    >
                </div>
            </div>
        </div>
    </section>

    <section id="faq">
        <div class="max-w">
            <div class="section-label">FAQ</div>
            <h2 class="section-title">Quick answers.</h2>

            <div class="faq-list">
                <details class="faq-item">
                    <summary>On-site or remote?</summary>
                    <p>
                        Either. We run it at your office or fully remote —
                        whatever suits your team.
                    </p>
                </details>
                <details class="faq-item">
                    <summary>How many engineers can join?</summary>
                    <p>
                        Up to 20 per workshop. That keeps every engineer close
                        to an instructor during the hands-on time.
                    </p>
                </details>
                <details class="faq-item">
                    <summary>Can we use our own codebase?</summary>
                    <p>
                        Yes — that's the point. We tailor the day to your stack
                        and real projects, and provide API keys at no extra cost.
                    </p>
                </details>
                <details class="faq-item">
                    <summary>What level do our engineers need?</summary>
                    <p>
                        Comfort reading and writing code is the baseline. We
                        cover tool fundamentals in the intro — no prior agent
                        experience needed.
                    </p>
                </details>
                <details class="faq-item">
                    <summary>Which tools do you use?</summary>
                    <p>
                        Claude Code or OpenAI Codex, with API keys provided.
                        Cursor users are welcome but won't get dedicated support.
                    </p>
                </details>
                <details class="faq-item">
                    <summary>How do we book?</summary>
                    <p>
                        Email <a href="mailto:dominik.grusemann@gmail.com"
                            >dominik.grusemann@gmail.com</a
                        > with your team size and rough dates. We'll scope it and
                        send a quote.
                    </p>
                </details>
            </div>
        </div>
    </section>

    <section id="updates">
        <div class="max-w">
            <div class="section-label">Updates</div>
            <h2 class="section-title">Hear about open sessions first.</h2>
            <p class="section-desc" style="margin-bottom: 32px">
                Open sessions, the Advanced AI Coding launch, and occasional
                field notes.
            </p>

            <form class="signup-form ml-form" method="POST">
                <div class="signup-prompt">
                    <span class="signup-path">~/updates</span>&nbsp;$&nbsp;
                </div>
                <div class="signup-input-wrap">
                    <input
                        type="email"
                        name="fields[email]"
                        class="signup-input"
                        placeholder="your@email.dev"
                        required
                        autocomplete="email"
                        aria-label="Email address"
                    />
                    <button type="submit" class="btn-ghost signup-btn">
                        subscribe
                    </button>
                </div>
                <input type="hidden" name="ml-submit" value="1" />
                <input type="hidden" name="anticsrf" value="true" />
            </form>

            <div class="signup-feedback"></div>

            <p class="signup-consent">
                By subscribing you agree to our
                <a href="/privacy/">privacy policy</a>. We store your email
                with
                <a
                    href="https://www.mailerlite.com"
                    target="_blank"
                    rel="noopener">MailerLite</a
                >
                (EU-based) and you can unsubscribe anytime.
            </p>
        </div>
    </section>

    <section id="sponsors">
        <div class="max-w">
            <p class="logo-strip-label">Partners who supported our first open session</p>
            <div class="sponsor-grid">
                {(nextEvent?.sponsors ?? pastEvents[0]?.sponsors ?? []).map((s) => (
                    <a
                        href={s.url}
                        class="sponsor-link"
                        target="_blank"
                        rel="noopener"
                        aria-label={s.name}
                    >
                        <img src={s.logo} alt={s.name} />
                    </a>
                ))}
            </div>
        </div>
    </section>

    <section id="final-cta">
        <div class="max-w" style="position: relative">
            <div class="cta-terminal">
                <span class="path">~/workshop</span>&nbsp;$&nbsp;<span
                    >book --workshop</span
                >
            </div>
            <h2 class="cta-title">
                Done vibe coding?<br />Train your team.
            </h2>
            <div
                style="display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;"
            >
                <a href={bookMailto} class="btn-primary">Get a quote →</a>
                <a href="/guide/" class="btn-ghost">Get the free guide →</a>
            </div>
        </div>
    </section>
</BaseLayout>

<script is:inline>
    (function () {
        /* Course tabs */
        var tabs = Array.prototype.slice.call(
            document.querySelectorAll(".course-tab"),
        );

        function activate(tab) {
            tabs.forEach(function (t) {
                var selected = t === tab;
                t.setAttribute("aria-selected", selected ? "true" : "false");
                var panel = document.getElementById(
                    t.getAttribute("aria-controls"),
                );
                if (panel) panel.hidden = !selected;
            });
        }

        tabs.forEach(function (tab) {
            tab.addEventListener("click", function () {
                activate(tab);
            });
        });

        /* Links that jump to a specific course tab (e.g. hero waitlist CTA) */
        document
            .querySelectorAll("[data-course-switch]")
            .forEach(function (link) {
                link.addEventListener("click", function () {
                    var target = document.getElementById(
                        "tab-" + link.getAttribute("data-course-switch"),
                    );
                    if (target) activate(target);
                });
            });

        if (
            location.hash === "#advanced" ||
            location.hash === "#waitlist"
        ) {
            var advanced = document.getElementById("tab-advanced");
            if (advanced) {
                activate(advanced);
                document
                    .getElementById("courses")
                    .scrollIntoView({ behavior: "instant", block: "start" });
            }
        }

        /* MailerLite signup — shared by the updates form and the v2 waitlist */
        document.querySelectorAll(".ml-form").forEach(function (form) {
            var feedback = form.parentElement.querySelector(
                ".signup-feedback",
            );

            form.addEventListener("submit", function (e) {
                e.preventDefault();
                var email = form.querySelector('[name="fields[email]"]');
                if (!email.value || !email.validity.valid) {
                    feedback.textContent =
                        "→ please enter a valid email address";
                    feedback.className = "signup-feedback error";
                    return;
                }

                var btn = form.querySelector(".signup-btn");
                var originalLabel = btn.textContent;
                btn.textContent = "sending…";
                btn.disabled = true;

                fetch(
                    "https://assets.mailerlite.com/jsonp/2239840/forms/183629273017354022/subscribe",
                    {
                        method: "POST",
                        body: new FormData(form),
                    },
                )
                    .then(function () {
                        feedback.textContent =
                            "✓ subscribed — you're on the list";
                        feedback.className = "signup-feedback success";
                        form.reset();
                        btn.textContent = "done ✓";
                    })
                    .catch(function () {
                        feedback.textContent =
                            "→ something went wrong — try again or email us";
                        feedback.className = "signup-feedback error";
                        btn.textContent = originalLabel;
                        btn.disabled = false;
                    });
            });
        });

        fetch(
            "https://assets.mailerlite.com/jsonp/2239840/forms/183629273017354022/takel",
        );
    })();
</script>

